# ==== General ====
NODE_ENV=development
PORT=4000
AI_SERVICE_URL=http://localhost:8000

# ==== Database ====
DATABASE_URL=postgresql://saferoute:saferoute_pass@localhost:5432/saferoute_db
REDIS_URL=redis://localhost:6379

# ==== Auth ====
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1h

# ==== LLM / RAG ====
LLM_PROVIDER=anthropic          # anthropic | openai
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=bge-large-en

# ==== Vector DB ====
VECTOR_DB_PROVIDER=pgvector      # pgvector | pinecone | weaviate
PINECONE_API_KEY=
PINECONE_ENV=
WEAVIATE_URL=

# ==== Maps ====
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ==== Notifications ====
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+10000000000
FCM_SERVER_KEY=your_firebase_cloud_messaging_key

# ==== Storage (SOS evidence media) ====
STORAGE_PROVIDER=s3               # s3 | firebase
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=saferoute-evidence
