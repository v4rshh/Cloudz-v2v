# Mapbox (VibeRoute map + live tracking)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ...
NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase (incident_reports, sos_events, Realtime)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=

# Twilio (SOS SMS with tracking link)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567

# Public site URL (used in SMS tracking links — use ngrok/tunnel URL for local Twilio testing)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Gemini (Sahara RAG chat — optional)
GEMINI_API_KEY=AIzaSy...
